{
  "$schema": "https://schema.stryker-mutator.io/stryker-config.json",
  "mutate": [
    "src/**/*.ts",
    "!src/**/index.ts",
    "!src/shared/types/*.ts"
  ],
  "testRunner": "vitest",
  "reporters": [
    "progress",
    "clear-text",
    "html",
    "json"
  ],
  "plugins": [
    "@stryker-mutator/vitest-runner"
  ],
  "checkers": [],
  "tsconfigFile": "tsconfig.json",
  "incremental": true,
  "incrementalFile": "reports/stryker-incremental.json",
  "coverageAnalysis": "perTest",
  "timeoutMS": 30000,
  "thresholds": {
    "high": 80,
    "low": 60,
    "break": 0
  },
  "htmlReporter": {
    "fileName": "reports/mutation/index.html"
  },
  "jsonReporter": {
    "fileName": "reports/mutation/mutation.json"
  }
}
